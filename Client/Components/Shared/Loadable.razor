@typeparam TItem
@implements IDisposable

@if (_loading)
{
    @if (Loading is not null)
    {
        @Loading
    }
}
else if (_error)
{
    @Error?.Invoke(ReloadAsync)
}
else if (_data is not null)
{
    @ChildContent?.Invoke(_data)
}

@code 
{
    [Parameter, EditorRequired]
    public Func<CancellationToken, Task<TItem>> Loader { get; set; } = default!;

    [Parameter]
    public RenderFragment<TItem>? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? Loading { get; set; }

    [Parameter]
    public RenderFragment<Func<Task>>? Error { get; set; }

    [Parameter] 
    public object? Key { get; set; }

    private TItem? _data;
    private object? _previous;
    private bool _loading, _error;

    private CancellationTokenSource? _cts;

    protected override async Task OnParametersSetAsync()
    {
        if (_cts is null || !Equals(_previous, Key))
        {
            _previous = Key;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();

        _cts = new();

        _loading = true;
        _error = false;

        try
        {
            _data = await Loader(_cts.Token);
        }
        catch (OperationCanceledException) { }
        catch
        {
            _error = true;
        }
        finally
        {
            _loading = false;
        }
    }

    public async Task ReloadAsync()
    {
        await LoadAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}