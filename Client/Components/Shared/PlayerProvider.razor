@inherits PulseComponent

@inject PlayerState State

<Audio @ref="_audio"
       src="@State.Source"
       OnLoadedMetadata="OnLoadedMetadata"
       OnTimeUpdate="OnTimeUpdate" />

<div class="@PlayerContainerClass">

    <div class="max-w-6xl mx-auto flex flex-col gap-3">

        <!-- Top Row -->
        <div class="flex items-center justify-between gap-4">

            <!-- Episode Info -->
            <div class="flex items-center gap-3 min-w-0">

                <img src="@State.Cover"
                     class="w-12 h-12 rounded-md object-cover bg-muted shrink-0" />

                <div class="min-w-0">
                    <div class="text-sm font-semibold truncate">
                        @State.Current?.Title
                    </div>

                    <div class="text-xs text-muted-foreground truncate flex items-center gap-2">

                        @if (@State.Current is { } episode)
                        {
                            @if (episode.Season > 0 || episode.Episode.HasValue)
                            {
                                <span>
                                    S@(episode.Season)
                                    @if (episode.Episode.HasValue)
                                    {
                                        <span>E@(episode.Episode)</span>
                                    }
                                </span>
                            }

                            <span>
                                @episode.DatePublished.ToString("MMM dd, yyyy")
                            </span>

                            @if (episode.Explicit)
                            {
                                <span class="px-1.5 py-0.5 text-[10px] bg-red-500/20 text-red-400 rounded">
                                    E
                                </span>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Controls -->
            <div class="flex items-center gap-2">

                <BbButton Size="ButtonSize.Icon"
                          Variant="ButtonVariant.Ghost"
                          @onclick="TogglePlay">
                    <LucideIcon Name="@(State.IsPlaying ? "pause" : "play")" />
                </BbButton>

                <BbButton Size="ButtonSize.Icon"
                          Variant="ButtonVariant.Ghost"
                          @onclick="StopAsync">
                    <LucideIcon Name="square" />
                </BbButton>

            </div>
        </div>

        <!-- Progress Row -->
        <div class="flex items-center gap-3">

            <span class="text-xs w-12 text-right tabular-nums">
                @FormatTime(State.CurrentTime)
            </span>

            <BbSlider Min="0"
                      Max="100"
                      Step="0.1"
                      @bind-Value:get="State.Progress"
                      @bind-Value:set="OnSliderChanged"
                      @bind-Value:format="0.##"
                      Class="flex-1" />

            <span class="text-xs w-12 tabular-nums">
                @FormatTime(State.EffectiveDuration)
            </span>

        </div>

    </div>
</div>

@code
{
    private Audio _audio = default!;

    private bool IsVisible => State.Current is not null;

    private string PlayerContainerClass => $"""
        fixed left-0 right-0 bottom-16
        z-10
        bg-background
        border-t border-border
        px-6 py-4
        transition-transform duration-300 ease-in-out
        {(IsVisible ? "translate-y-0" : "translate-y-full")}
        """;

    protected override void OnInitialized()
    {
        Track(State);
    }

    private async Task TogglePlay()
    {
        if (State.IsPlaying)
        {
            await _audio.PauseAsync();
            State.IsPlaying = false;
        }
        else
        {
            await _audio.PlayAsync();
            State.IsPlaying = true;
        }
    }

    private async Task StopAsync()
    {
        await _audio.StopAsync();
        State.Clear();

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnLoadedMetadata()
    {
        State.CurrentDuration = await _audio.GetDurationAsync();
        await _audio.PlayAsync();
        State.IsPlaying = true;
    }

    private async Task OnTimeUpdate()
    {
        State.CurrentTime = await _audio.GetCurrentTimeAsync();
    }

    private async Task OnSliderChanged(double percent)
    {
        if (State.EffectiveDuration <= 0)
            return;

        var newTime = (percent / 100.0) * State.EffectiveDuration;

        State.CurrentTime = newTime;
        await _audio.SetCurrentTimeAsync(newTime);
    }

    private static string FormatTime(double seconds)
    {
        if (seconds <= 0)
            return "00:00";

        var ts = TimeSpan.FromSeconds(seconds);
        return $"{(int)ts.TotalMinutes:00}:{ts.Seconds:00}";
    }
}