@using Client.Components.Pages.Home.Shared.Skeletons
@inject PodcastIndexClient Client

<HeaderContent Class="px-3 ps-4">

    <BbAvatar>
        <BbAvatarFallback Class="bg-primary">D</BbAvatarFallback>
    </BbAvatar>

    <Loadable Loader="LoadCategoriesAsync">

        <Loading>
            <CategorySkeleton />
        </Loading>

        <ChildContent Context="categories">
            <CategorySelector Categories="@categories"
                              Selected="@Selected"
                              OnToggle="@OnToggle" />
        </ChildContent>

    </Loadable>

</HeaderContent>

@code
{
    [Parameter] public HashSet<string> Selected { get; set; } = [];
    [Parameter] public EventCallback<string> OnToggle { get; set; }

    private async Task<IEnumerable<Category>> LoadCategoriesAsync(CancellationToken ct)
    {
        var response = await Client.Categories.ListAsync(ct);
        return response.Categories;
    }
}