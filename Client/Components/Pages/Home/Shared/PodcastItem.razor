<BbItem AsChild="a" Href="@($"/podcasts/{Item.Id}")" Variant="ItemVariant.Muted" Size="ItemSize.Sm">
    <BbItemMedia>
        <img class="size-12 rounded object-cover" src="@Item.Image" alt="@(Item.Title)'s image" />
    </BbItemMedia>
    <BbItemContent Class="min-w-0">
        <BbItemTitle Class="line-clamp-1!">@Item.Title</BbItemTitle>
        <BbItemDescription Class="line-clamp-1!">@Regexes.StripHtml(Item.Description)</BbItemDescription>
    </BbItemContent>
</BbItem>

@code
{
    [Parameter, EditorRequired] public PodcastSummary Item { get; set; } = default!;
}