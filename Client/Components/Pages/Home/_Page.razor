@page "/"
@using Client.Components.Pages.Home.Shared

<HomeHeader Selected="@_selected"
            OnToggle="Toggle" />

<div class="space-y-8">

    <PodcastGrid Categories="@Categories" />

    <TrendingSection />

    <DiscoverEpisodesSection />

</div>

@code
{
    private HashSet<string> _selected = [];

    private string[] Categories => _selected.ToArray();

    private void Toggle(string categoryName)
    {
        if (!_selected.Add(categoryName))
            _selected.Remove(categoryName);
    }
}