@page "/{id:int}"

@inject PodcastIndexClient Client

@code
{
    [Parameter] public int Id { get; set; }

    private PodcastDto? podcast;
    private List<EpisodeDto> episodes = [];
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;

            var p = Client.Podcasts.ByFeedIdAsync(Id);
            var e = Client.Episodes.ByFeedIdAsync(Id);

            await Task.WhenAll(p, e);

            podcast = p.Result.Value;
            episodes = e.Result.Items;
        }
        finally
        {
            isLoading = false;
        }
    }
}
