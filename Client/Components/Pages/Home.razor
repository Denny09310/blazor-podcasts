@page "/"

@inject PodcastIndexClient Client
@inject ToastService Toast

<HeaderContent Class="px-3 ps-4">

    <BbAvatar>
        <BbAvatarFallback Class="bg-primary">D</BbAvatarFallback>
    </BbAvatar>

    @if (categories is null)
    {
        <div class="no-scrollbar flex flex-1 gap-2 overflow-x-auto rounded-s-full">
            @for (int i = 0; i < 6; i++)
            {
                <BbSkeleton Class="h-8 w-20 shrink-0 rounded-full" />
            }
        </div>
    }
    else if (categories.Categories?.Any() == true)
    {

        <div class="no-scrollbar flex flex-1 gap-2 overflow-x-auto rounded-s-full">

            @foreach (var category in categories.Categories)
            {
                var classes = selected.Contains(category.Id)
                ? "bg-muted text-muted-foreground"
                : "bg-muted-light text-muted-foreground active:scale-95";

                <button @key="category.Id"
                        class="shrink-0 rounded-full px-4 py-2 text-sm font-medium transition-all @classes"
                        @onclick="@(() => ToggleAsync(category.Id))">
                    @category.Name
                </button>
            }

        </div>
    }

</HeaderContent>

<div class="space-y-8">

    @if (loading)
    {
        <div class="grid grid-cols-2 gap-3">
            @for (int i = 0; i < 6; i++)
            {
                <div class="flex animate-pulse gap-x-2 rounded bg-muted-light p-2">
                    <BbSkeleton Class="size-12 shrink-0 rounded" />
                    <div class="flex-1 space-y-1">
                        <BbSkeleton Class="h-3 w-3/4 rounded" />
                        <BbSkeleton Class="h-3 w-1/2 rounded" />
                    </div>
                </div>
            }
        </div>
    }
    else if (bycategory?.Searches?.Any() == true)
    {
        <div class="grid grid-cols-2 gap-3">
            @foreach (var item in bycategory.Searches)
            {

                <a @key="item.Id"
                   href="@($"/podcasts/{item.Id}")"
                   class="flex items-center gap-x-3 rounded bg-muted p-2 transition hover:bg-muted-dark">

                    <img class="size-12 rounded object-cover"
                         src="@item.Image"
                         alt="@(item.Title)'s image" />

                    <div class="min-w-0 flex-1 space-y-1">
                        <h3 class="truncate text-sm font-semibold">
                            @item.Title
                        </h3>
                        <p class="truncate text-xs opacity-75">
                            @Regexes.GetHtmlTags().Replace(item.Description, "")
                        </p>
                    </div>

                </a>
            }
        </div>
    }

    <section id="trending-from-monday" class="space-y-3">

        <h2 class="text-lg font-bold tracking-tight text-foreground">
            Trending from Monday
        </h2>

        @if (trending == null)
        {
            <div class="no-scrollbar flex gap-3 overflow-x-auto">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="w-24 shrink-0 space-y-2">
                        <BbSkeleton Class="size-24 rounded-md" />
                        <BbSkeleton Class="h-3 w-3/4 rounded" />
                        <BbSkeleton Class="h-3 w-1/2 rounded" />
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-scrollbar flex gap-3 overflow-x-auto">
                @foreach (var item in trending.Searches)
                {
                    <a @key="item.Id"
                       href="@($"/podcasts/{item.Id}")"
                       class="w-24 shrink-0 space-y-2">

                        <img class="size-24 rounded-md object-cover"
                             src="@item.Image"
                             alt="@(item.Title)'s image" />

                        <div class="space-y-1">
                            <h3 class="truncate text-sm font-semibold">
                                @item.Title
                            </h3>
                            <p class="truncate text-xs opacity-75">
                                @item.Author
                            </p>
                        </div>

                    </a>
                }
            </div>
        }

    </section>

    <section id="random-podcast-episodes" class="space-y-4">

        <h2 class="text-lg font-bold tracking-tight text-foreground">
            Discover Episodes
        </h2>

        @if (episodes == null)
        {
            @for (int i = 0; i < 2; i++)
            {
                <div class="space-y-3">
                    <div class="flex items-center gap-4">
                        <BbSkeleton Class="size-12 rounded" />
                        <div class="flex-1 space-y-2">
                            <BbSkeleton class="h-3 w-3/4 rounded"/>
                            <BbSkeleton class="h-3 w-1/2 rounded"/>
                        </div>
                    </div>
                    <BbSkeleton Class="aspect-video rounded-md" />
                </div>
            }
        }
        else
        {
            <div class="flex flex-col gap-6">
                @foreach (var item in episodes.Episodes)
                {
                    <div @key="item.Id" class="space-y-3">

                        <div class="flex items-center gap-4">

                            <img class="size-12 shrink-0 rounded object-cover"
                                 src="@item.Image"
                                 alt="@(item.Title)'s image" />

                            <div class="min-w-0 flex-1 space-y-1">
                                <h3 class="truncate text-sm font-semibold">
                                    @item.Title
                                </h3>
                                <p class="truncate text-xs opacity-75">
                                    @item.FeedTitle
                                </p>
                            </div>

                            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="rounded-full">
                                <LucideIcon Name="ellipsis-vertical" />
                            </BbButton>

                        </div>

                        <img class="aspect-video rounded-md object-cover"
                             src="@item.Image"
                             alt="@(item.Title)'s image" />

                    </div>
                }
            </div>
        }

    </section>

</div>

@code
{
    private SearchResponse? bycategory, trending;
    private CategoriesResponse? categories;
    private RandomEpisodesResponse? episodes;

    private bool loading = true;

    private HashSet<long> selected = [];
    private CancellationTokenSource? cts;

    private string[] Selected =>
        categories?.Categories
            .Where(c => selected.Contains(c.Id))
            .Select(c => c.Name)
            .ToArray() ?? [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var task1 = Client.Categories.ListAsync();
            var task2 = Client.Podcasts.TrendingAsync(new TrendingRequest
            {
                Max = 12,
                Since = GetLastMonday(),
            });
            var task3 = Client.Episodes.RandomAsync(new RandomEpisodesRequest { Max = 2 });

            await Task.WhenAll(task1, task2, task3);

            categories = task1.Result;
            trending = task2.Result;
            episodes = task3.Result;
        }
        catch (OperationCanceledException) { }
        catch (Exception)
        {
            Toast.Error(description: "Can't load data at the moment.");
        }

        await PopulateAsync();
    }

    private async Task PopulateAsync()
    {
        try
        {
            cts?.Cancel();
            cts = new CancellationTokenSource();

            loading = true;

            bycategory = await Client.Podcasts.TrendingAsync(
                request: new TrendingRequest { Max = 6, Cat = Selected },
                ct: cts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception)
        {
            Toast.Error(description: "Can't load trending podcasts at the moment.");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ToggleAsync(long categoryId)
    {
        if (!selected.Add(categoryId))
            selected.Remove(categoryId);

        await PopulateAsync();
    }

    public static DateTime GetLastMonday(bool includeToday = true)
    {
        DateTime today = DateTime.Now;
        int diff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;

        if (!includeToday && diff == 0)
            diff = 7;

        return today.AddDays(-diff).Date;
    }
}