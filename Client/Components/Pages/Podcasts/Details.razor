@page "/podcasts/{Id:int}"
@using Client.Components.Pages.Podcasts.Shared
@using Client.Components.Pages.Podcasts.Shared.Skeletons

@inject PodcastIndexClient Client
@inject ToastService Toast

<PodcastHeader Title="podcast?.Title" />

<div class="space-y-8">

    @if (loading)
    {
        <PodcastDetailsSkeleton />
        <EpisodeListSkeleton />
    }
    else if (podcast is not null)
    {
        <PodcastDetailsSection Podcast="@podcast" />

        <EpisodeListSection Image="@podcast.Image"
                            Episodes="@episodes" />
    }

</div>

@code
{
    [Parameter] public int Id { get; set; }

    private Podcast? podcast;
    private List<Episode> episodes = [];

    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;

            var task1 = Client.Podcasts.ByFeedIdAsync(Id);
            var task2 = Client.Episodes.ByFeedIdAsync(Id);

            await Task.WhenAll(task1, task2);

            podcast = task1.Result.Value;
            episodes = task2.Result.Items;
        }
        catch (OperationCanceledException) { }
        catch (Exception)
        {
            Toast.Error("Can't load podcast details at the moment.");
        }
        finally
        {
            loading = false;
        }
    }
}