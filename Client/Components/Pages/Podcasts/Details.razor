@page "/podcasts/{Id:int}"
@using Client.Components.Pages.Podcasts.Shared
@using Client.Components.Pages.Podcasts.Shared.Skeletons

@inject PodcastIndexClient Client
@inject ToastService Toast

<PodcastHeader Title="podcast?.Title" />

<div class="space-y-8">

    @if (_loading)
    {
        <PodcastDetailsSkeleton />
        <EpisodeListSkeleton />
    }
    else if (_podcast is not null)
    {
        <PodcastDetailsSection Podcast="@_podcast" />

        <EpisodeListSection Image="@_podcast.Image"
                            Episodes="@_episodes" />
    }

</div>

@code
{
    [Parameter] public int Id { get; set; }

    private CancellationTokenSource? _cts;

    private Podcast? _podcast;
    private List<Episode> _episodes = [];

    private bool _loading = true;


    protected override async Task OnParametersSetAsync()
    {
        _cts?.Cancel();
        _cts = new();

        try
        {
            _loading = true;

            var task1 = Client.Podcasts.ByFeedIdAsync(Id, _cts.Token);
            var task2 = Client.Episodes.ByFeedIdAsync(Id, _cts.Token);

            await Task.WhenAll(task1, task2);

            _podcast = task1.Result.Value;
            _episodes = task2.Result.Items;
        }
        catch (OperationCanceledException) { }
        catch (Exception)
        {
            Toast.Error("Can't load podcast details at the moment.");
        }
        finally
        {
            _loading = false;
        }
    }
}