@page "/podcasts/{Id:int}"
@using Client.Components.Pages.Podcasts.Shared
@using Client.Components.Pages.Podcasts.Shared.Skeletons

@inject PodcastIndexClient Client

<PodcastHeader Title="@_podcast?.Title" />

<div class="space-y-8">

    <Loadable Loader="LoadPodcastAsync">

        <Loading>
            <PodcastDetailsSkeleton />
        </Loading>

        <Error>
            <BbAlert Variant="AlertVariant.Danger">
                <BbAlertTitle>Error</BbAlertTitle>
                <BbAlertDescription>Failed to load podcast.</BbAlertDescription>
            </BbAlert>
        </Error>

        <ChildContent Context="podcast">
            <PodcastDetailsSection Podcast="@podcast" />
        </ChildContent>

    </Loadable>

    <Loadable Loader="LoadEpisodesAsync">

        <Loading>
            <EpisodeListSkeleton />
        </Loading>

        <Error>
            <BbAlert Variant="AlertVariant.Danger">
                <BbAlertTitle>Error</BbAlertTitle>
                <BbAlertDescription>Failed to load episodes.</BbAlertDescription>
            </BbAlert>
        </Error>

        <ChildContent Context="episodes">
            <EpisodeListSection Episodes="@episodes" Image="@_podcast?.Image" />
        </ChildContent>

    </Loadable>

</div>

@code
{
    [Parameter] public int Id { get; set; }

    private Podcast? _podcast;

    private async Task<Podcast> LoadPodcastAsync(CancellationToken ct)
    {
        var response = await Client.Podcasts.ByFeedIdAsync(Id, ct);
        _podcast = response.Value;
        
        return _podcast;
    }

    private async Task<List<Episode>> LoadEpisodesAsync(CancellationToken ct)
    {
        var response = await Client.Episodes.ByFeedIdAsync(Id, ct);
        return response.Items;
    }
}