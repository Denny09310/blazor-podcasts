@using Client.Components.Pages.Podcasts.Shared
@using Client.Components.Pages.Podcasts.Shared.Skeletons

@inject PodcastIndexClient Client
@inject PlayerState Player

<Loadable Loader="LoadEpisodesAsync" Key="@Podcast">

    <Loading>
        <EpisodeListSkeleton />
    </Loading>

    <Error>
        <BbAlert Variant="AlertVariant.Danger">
            <BbAlertTitle>Error</BbAlertTitle>
            <BbAlertDescription>Failed to load episodes.</BbAlertDescription>
        </BbAlert>
    </Error>

    <ChildContent Context="episodes">
        <section class="space-y-4">

            <h3 class="text-lg font-bold tracking-tight">
                Episodes
            </h3>

            @if (episodes.Count != 0)
            {
                <div class="flex flex-col gap-4">
                    @foreach (var episode in episodes)
                    {
                        <EpisodeListItem @key="episode.Id"
                                         Episode="@episode"
                                         Image="@Podcast?.Image"
                                         OnPlay="(e) => Player.SetCurrent(e)" />
                    }
                </div>
            }
            else
            {
                <BbEmpty Description="No episodes found." />
            }

        </section>
    </ChildContent>

</Loadable>

@code
{
    [Parameter, EditorRequired]
    public int Id { get; set; }

    [Parameter]
    public Podcast? Podcast { get; set; }

    private async Task<List<Episode>> LoadEpisodesAsync(CancellationToken ct)
    {
        var response = await Client.Episodes.ByFeedIdAsync(Id, ct);
        return response.Items;
    }
}