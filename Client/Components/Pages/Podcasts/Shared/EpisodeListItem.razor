@using Humanizer

<BbCard Class="shadow-none">
    <BbCardContent>
        <BbItem>
            <BbItemMedia>
                <img class="size-12 shrink-0 rounded object-cover"
                     src="@(!string.IsNullOrEmpty(Episode.Image) ? Episode.Image : Image)"
                     alt="@(Episode.Title)'s image" />
            </BbItemMedia>
            <BbItemContent>
                <BbItemTitle>@Episode.Title</BbItemTitle>
                <BbItemDescription>@Episode.DatePublished.Humanize()</BbItemDescription>
            </BbItemContent>
            <BbItemActions>
                <BbButton Size="ButtonSize.Icon" Class="rounded-full">
                    <LucideIcon Name="play" />
                </BbButton>
            </BbItemActions>
        </BbItem>

        @if (!string.IsNullOrWhiteSpace(Episode.Description))
        {
            <BbTypographyP Class="line-clamp-3">
                @Regexes.StripHtml(Episode.Description)
            </BbTypographyP>
        }
    </BbCardContent>
</BbCard>

@code
{
    [Parameter, EditorRequired]
    public Episode Episode { get; set; } = default!;

    [Parameter]
    public string? Image { get; set; }
}