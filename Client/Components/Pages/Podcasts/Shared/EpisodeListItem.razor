@using Humanizer

<BbCard>
    <BbCardContent>
        <BbItem Class="px-0">
            <BbItemMedia>
                <img class="size-12 shrink-0 rounded object-cover"
                     src="@(!string.IsNullOrEmpty(Episode.Image) ? Episode.Image : Image)"
                     alt="@(Episode.Title)'s image" />
            </BbItemMedia>
            <BbItemContent Class="min-w-0">
                <BbItemTitle Class="truncate">@Episode.Title</BbItemTitle>
                <BbItemDescription>@Episode.DatePublished.Humanize()</BbItemDescription>
            </BbItemContent>
            <BbItemActions>
                <BbButton Size="ButtonSize.Icon" Class="rounded-full" @onclick="PlayAsync">
                    <LucideIcon Name="play" />
                </BbButton>
            </BbItemActions>
        </BbItem>

        @if (!string.IsNullOrWhiteSpace(Episode.Description))
        {
            <BbTypographyMuted Class="line-clamp-3">
                @Regexes.StripHtml(Episode.Description)
            </BbTypographyMuted>
        }
    </BbCardContent>
</BbCard>

@code
{
    [Parameter, EditorRequired]
    public Episode Episode { get; set; } = default!;

    [Parameter]
    public string? Image { get; set; }

    [Parameter]
    public EventCallback<Episode> OnPlay { get; set; }

    private Task PlayAsync()
    {
        return OnPlay.InvokeAsync(Episode);
    }
}