{
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "podcastindex": {
        "ClusterId": "podcastindexCluster",
        "OutputCachePolicy": "podcastindexPolicy",
        "Match": {
          "Path": "/podcastindex/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/podcastindex" }
        ]
      }
    },
    "Clusters": {
      "podcastindexCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://api.podcastindex.org/api/1.0/"
          }
        }
      }
    }
  }
}